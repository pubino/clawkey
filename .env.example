# Portkey AI Sandbox credentials
# Provided by your institution's AI Sandbox
AI_SANDBOX_KEY=<your-portkey-api-key>

# Model to use (must be available through Portkey gateway)
# OpenAI: gpt-4o-mini, gpt-5-mini, and all gpt/o series
# Google: gemini-3.1-pro-preview, and all Gemini models
# Meta (via Azure): Llama-3.3-70B-Instruct, Meta-Llama-3-1-8B-Instruct
# Mistral: mistral-small-2503, mistral-medium-2505
PORTKEY_MODEL=gemini-3.1-pro-preview

# LiteLLM proxy master key (auto-generated if not set)
LITELLM_MASTER_KEY=sk-clawkey-local
